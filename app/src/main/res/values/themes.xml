<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TripGuard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">#0F172A</item>
        <item name="android:navigationBarColor">#F8FAFC</item>
        <item name="colorPrimary">#EA580C</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#155EEF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#0F172A</item>
    </style>

    <style name="TripGuardBottomNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_nav_item</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingTop">7dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/bottom_nav_text</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
